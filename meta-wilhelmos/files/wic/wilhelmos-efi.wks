# WilhelmOS UEFI-bootable GPT disk image for generic x86-64 (production).
# For a variant with verbose serial-console kernel args (useful when
# dd'ing to USB for bare-metal debugging), see wilhelmos-efi-debug.wks.

part /boot --source bootimg-efi --sourceparams="loader=systemd-boot" --label boot --active --align 4096

part / --source rootfs --fstype=ext4 --label rootfs --align 4096

bootloader --ptable=gpt --timeout=3 --append="root=PARTLABEL=rootfs rootwait"
